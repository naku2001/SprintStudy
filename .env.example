# Fill API keys and model/storage settings before starting.

# ============================
# API Keys (fill these)
# ============================
GEMINI_API_KEY=your_gemini_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
TOGETHER_API_KEY=your_together_api_key_here

# ============================
# Generation Model
# ============================
GENERATION_PROVIDER=gemini
GENERATION_MODEL=
GEMINI_MODEL=gemini-2.5-flash
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=openai/gpt-oss-120b

# ============================
# Embedding Model
# ============================
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
HUGGINGFACE_API_URL=
GEMINI_EMBED_MAX_BATCH=100

# ============================
# Pinecone Storage
# ============================
PINECONE_INDEX_NAME=sprintstudy-main
PINECONE_NAMESPACE=default
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_UPSERT_MAX_RECORDS=60
PINECONE_UPSERT_MAX_BYTES=1500000

# ============================
# Chunking & Summary Behavior
# ============================
CHUNK_MAX_CHARS=2400
CHUNK_OVERLAP=80
SUMMARY_SINGLE_PASS_MAX_CHUNKS=80
SUMMARY_SINGLE_PASS_MAX_INPUT_CHARS=120000
SUMMARY_BATCH_TARGET_COUNT=5
SUMMARY_MAX_BATCHES=5
SUMMARY_BATCH_MAX_CHUNKS=12
SUMMARY_BATCH_MAX_CHARS=18000
SUMMARY_BATCH_SLEEP_MS=0

# ============================
# Local Paths
# ============================
STUDY_NOTES_DIR=backend/data/uploads_tmp
